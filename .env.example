# EmailJS — formulario de contacto (https://www.emailjs.com)
# Opcional: sobreescribe los valores de src/data/site.ts si lo prefieres por entorno.
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=

# YouTube Data API v3 — sincronización automática de música (docs/YOUTUBE_SYNC.md)
# Obligatoria para actualizar el catálogo desde tu canal al hacer build.
YOUTUBE_API_KEY=
# Handle del canal sin @ (por defecto: Ryderd23)
YOUTUBE_CHANNEL_HANDLE=Ryderd23
# Opcional: ID del canal UC... si el handle no se resuelve
YOUTUBE_CHANNEL_ID=
# Máximo de canciones a importar vía API (0 = catálogo completo sin límite, por defecto 0)
YOUTUBE_MAX_VIDEOS=0
# Excluir Shorts por duración (1 = sí, 0 = no)
YOUTUBE_FILTER_SHORTS=1
# Duración máxima en segundos para considerar un video como Short
YOUTUBE_SHORT_MAX_SECONDS=60
# Ver en consola qué videos se excluyen y por qué
YOUTUBE_SYNC_VERBOSE=0
